.container {
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.form {
  margin-bottom: 48rpx;
}

.picker-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.12);
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 32rpx;
  color: #333;
}

.btn {
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.result {
  margin-top: 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  text-align: center;
}

.img-wrap {
  margin-bottom: 24rpx;
}

.pokemon-img {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 16rpx;
  display: block;
}

.btn-refresh {
  display: block;
  margin: 0 auto;
  width: auto;
  min-width: 160rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #4a90d9;
  background: #f0f7ff;
  border: none;
  border-radius: 12rpx;
}

.btn-refresh::after {
  border: none;
}

.info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.dex-no {
  font-size: 26rpx;
  color: #888;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.name-zh {
  margin-bottom: 4rpx;
}

.name-row {
  display: block;
  font-size: 28rpx;
  color: #555;
  text-align: center;
}

.name-label {
  color: #888;
  font-size: 24rpx;
  margin-right: 8rpx;
}
